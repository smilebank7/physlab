{
  "name": "physlab-mac-mcp",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "MCP server for physlab MuJoCo simulation tools.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smilebank7/physlab.git",
    "directory": "mcp-server"
  },
  "keywords": [
    "agentic",
    "mcp",
    "mujoco",
    "physical-ai",
    "robotics",
    "simulation"
  ],
  "bin": {
    "physlab-mac-mcp": "dist/server.js",
    "physlab-mcp-server": "dist/server.js"
  },
  "main": "./dist/server.js",
  "module": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && node scripts/fix-dts.mjs && bun build src/server.ts --outdir=dist --target=node --external @modelcontextprotocol/sdk --external ajv --external pino --external zod",
    "check": "biome check .",
    "check:licenses": "python ../tools/check_licenses.py --all",
    "docs": "typedoc --options typedoc.json",
    "mcp-server": "bun src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "license-checker-rseidelsohn": "^5.0.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
